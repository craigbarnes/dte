open
set -l auto-indent true
set -l expand-tab true
set -l emulate-tab true
set -l indent-width 4
insert -k "line 1\n\tline 2\n\tline 3\nline 4\n\tline 5"
up -l
up -l
up -l
up -l
indent
indent 1
indent +1
indent -r
indent -r
indent -r 1
indent -- -1
indent
indent
save -f build/test/indent.txt
close -f
